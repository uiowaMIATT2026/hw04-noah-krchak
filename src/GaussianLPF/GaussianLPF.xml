<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.nkrchak</category>
    <title>GaussianLPF_nkrchak</title>
    <description>
        Performs Gaussian low-pass filter on the input image
    </description>
    <version>1.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Noah Krchak</contributor>
    <contributor>Hans J. Johnson</contributor>
    <acknowledgements>Hans J. Johnson provided starter code and XML file for SimpleThreshold.  This builds from SimpleThreshold.xml.</acknowledgements>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>input</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>output</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>


    <parameters>
        <label>Filter Parameters</label>
        <description>Parameters for the Gaussian low-pass filter</description>
        <double>
            <name>
                sigma
            </name>
            <longflag>
                sigma
            </longflag>
            <label>
                Sigma
            </label>
            <description>
                Sigma for X, Y, and Z directions for Gaussian low-pass filter
            </description>
            <default>
                2.5
            </default>
            <constraints>
                <minimum>
                    0
                </minimum>
            </constraints>
        </double>
    </parameters>
</executable>
