<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.nkrchak</category>
    <title>GradientAD_nkrchak</title>
    <description>
        Performs gradient anisotropic diffusion on the input image
    </description>
    <version>97.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Hans J. Johnson</contributor>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>input</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>output</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>


    <parameters>
        <label>Filter Parameters</label>
        <description>Parameters for the gradient anisotropic diffusion filter</description>
        <double>
            <name>
                conductance
            </name>
            <longflag>
                conductance
            </longflag>
            <label>
                Conductance
            </label>
            <description>
                Conductance for gradient anisotropic diffusion  filter
            </description>
            <default>
                2.0
            </default>
        </double>
        <double>
            <name>
                timeStep
            </name>
            <longflag>
                timeStep
            </longflag>
            <label>
                Time Step
            </label>
            <description>
                Time step for gradient anisotropic diffusion filter
            </description>
            <default>
                0.1
            </default>
        </double>
        <integer>
            <name>
                iterations
            </name>
            <longflag>
                iterations
            </longflag>
            <label>
                Iterations
            </label>
            <description>
                Number of iterations for gradient anisotropic diffusion filter
            </description>
            <default>
                5
            </default>
            <constraints>
                <minimum>
                    1
                </minimum>
            </constraints>
        </integer>
    </parameters>
</executable>
