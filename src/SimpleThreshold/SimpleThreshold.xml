<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.nkrchak</category>
    <title>SimpleThreshold_nkrchak</title>
    <description>
        Performs binary thresholding on the input image
    </description>
    <version>97.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Noah Krchak</contributor>
    <contributor>Hans J. Johnson</contributor>
    <acknowledgements>Hans J. Johnson provided starter code and XML file for SimpleThreshold</acknowledgements>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>input</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>output</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>


    <parameters>
        <label>Threshold Parameters</label>
        <description>Parameters for the binary threshold filter</description>
        <integer>
            <name>
                lowThreshold
            </name>
            <longflag>
                lowThreshold
            </longflag>
            <label>
                Low Threshold
            </label>
            <description>
                Lowest range of pixel intensity that is considered to be inside the threshold
            </description>
            <default>
                50
            </default>
            <constraints>
                <minimum> <!-->Given the example parameters in README.md it is safe to assume that unsigned char min and max is acceptable<-->
                    0
                </minimum> <!-->Allows the user to adjust the pixel intensity in a fine-grain matter<-->
                <step>
                    1
                </step>
                <maximum><!-->See minimum comment<-->
                    255
                </maximum>
            </constraints>
        </integer>
        <integer>
            <name>
                highThreshold
            </name>
            <longflag>
                highThreshold
            </longflag>
            <label>
                High Threshold
            </label>
            <description>
                Highest range of pixel intensity that is considered to be inside the threshold
            </description>
            <default>
                100
            </default>
            <constraints>
                <minimum><!--> Same as lowThreshold constraints <-->
                    0
                </minimum>
                <step>
                    1
                </step>
                <maximum>
                    255
                </maximum>
            </constraints>
        </integer>
        <integer>
            <name>
                outsideValue
            </name>
            <longflag>
                outsideValue
            </longflag>
            <label>
                Outside Value
            </label>
            <description>
                Value to set all pixels to that are outside the threshold range
            </description>
            <default>
                150
            </default>
            <constraints>
                <minimum> <!-->Same as lowThreshold constraints<-->
                    0
                </minimum>
                <step>
                    1
                </step>
                <maximum>
                    255
                </maximum>
            </constraints>
        </integer>
        <integer>
            <name>
                insideValue
            </name>
            <longflag>
                insideValue
            </longflag>
            <label>
                Inside Value
            </label>
            <description>
                Value to set all pixels to that are inside the threshold range
            </description>
            <default>
                200
            </default>
            <constraints>
                <minimum><!-->Same as lowThreshold constraints<-->
                    0
                </minimum>
                <step>
                    1
                </step>
                <maximum>
                    255
                </maximum>
            </constraints>
        </integer>
    </parameters>
</executable>
